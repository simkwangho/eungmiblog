rules_version = '2';
// Firebase 콘솔 > Firestore Database > 규칙 탭에 이 내용을 붙여넣으세요.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 사용자 프로필: 본인 또는 관리자만 조회/수정 가능.
    // role, withdrawn 필드는 본인이 임의로 바꿀 수 없음(관리자만 변경 가능) — 탈퇴 처리 우회 방지.
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && request.resource.data.role == 'user';
      allow update: if (isOwner(uid)
          && request.resource.data.role == resource.data.role
          && request.resource.data.get('withdrawn', false) == resource.data.get('withdrawn', false))
        || isAdmin();
      allow delete: if isAdmin();
    }

    // 일감 목록: 비로그인 사용자도 조회 가능(홈페이지 공개용). 등록/수정/삭제는 관리자만.
    match /jobs/{jobId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // 신청/제출 내역: 본인 또는 관리자만 조회 가능.
    // 생성은 본인 명의로만, 상태 변경은 '신청완료'(최초 제출) 또는 '반려됨'(재제출) 상태에서
    // 본인이 제출/재제출할 때만 허용하고 그 외 상태 전환(승인/거절/정산완료)은 관리자만 가능.
    match /applications/{appId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid &&
          (resource.data.status == '신청완료' || resource.data.status == '반려됨'));
      allow delete: if isAdmin();
    }

    // 리뷰어 보유 계정(플랫폼 링크): 본인 또는 관리자만 조회 가능.
    // 생성은 본인 명의 + 반드시 '대기' 상태로만 가능(스스로 승인 불가). 승인/거절(상태·거절사유 변경)은 관리자만.
    // 삭제는 본인(원하면 계정 정리) 또는 관리자 모두 가능.
    match /subAccounts/{subId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == '대기';
      allow update: if isAdmin();
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }
  }
}
